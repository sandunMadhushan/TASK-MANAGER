# Copy to `.env.production` — Vite loads this for `npm run build` / `tauri build` (overrides `.env` for these keys).
# Use your real public API and Novu URLs (no localhost).
# Desktop (Tauri): `http://` API URLs are OK — the app uses the native HTTP plugin so mixed content does not apply.

VITE_API_URL=https://api.yourdomain.com/api
VITE_NOVU_APPLICATION_IDENTIFIER=
VITE_NOVU_BACKEND_URL=https://eu.api.novu.co
VITE_NOVU_SOCKET_URL=wss://eu.ws.novu.co
