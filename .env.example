PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/task-manager
# Local dev: Vite origin. Production: comma-separated frontend origins (first = email links). Example:
# CLIENT_ORIGIN=https://taskmanager.madhushan.me,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173
# `npm run build` / Tauri: use `.env.production` with a public VITE_API_URL (see .env.production.example); localhost is rejected in production bundles.
VITE_API_URL=http://localhost:4000/api
NOVU_API_KEY=
NOVU_BACKEND_URL=http://localhost:3000
NOVU_WORKFLOW_TASK_ASSIGNED=task-assigned
NOVU_WORKFLOW_TASK_COMPLETED=task-completed
NOVU_WORKFLOW_DEADLINE_NEAR=task-deadline-near
NOVU_WORKFLOW_PASSWORD_RESET=password-reset
NOVU_WORKFLOW_WELCOME=welcome-user
NOVU_WORKFLOW_TEAM_INVITE_SENT=team-invite-sent
NOVU_WORKFLOW_TEAM_INVITE_ACCEPTED=team-invite-accepted
NOVU_WORKFLOW_TEAM_INVITE_DECLINED=team-invite-declined
NOVU_WORKFLOW_TEAM_INVITE_JOINED=team-invite-joined
NOVU_WORKFLOW_PROJECT_CREATED=project-created
NOVU_WORKFLOW_PROJECT_DELETED=project-deleted
VITE_NOVU_APPLICATION_IDENTIFIER=
VITE_NOVU_BACKEND_URL=http://localhost:5000
VITE_NOVU_SOCKET_URL=ws://localhost:3002
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_EXPIRES_IN=7d
AUTH_DEFAULT_PASSWORD=Pass@12345
AUTH_PASSWORD_RESET_TOKEN_MINUTES=30
